# ─── Cockpit Purple Team — variables d'environnement (exemple) ───────────────
# Copier en `.env` (gitignoré). En production, injecter les secrets hors dépôt.
#
# ⚡ SECRETS : `make secrets` (idempotent, lancé automatiquement par make up/migrate/
#    test*) remplace les valeurs « change-me… » ci-dessous par des secrets forts.
#    Restent manuels car provisionnés hors périmètre : VAULT_TOKEN (make init-vault)
#    et OIDC_CLIENT_SECRET (secret client de la realm Keycloak).

# Exposition réseau (DAT §4.1bis) — un seul service publie : le frontend Nginx.
EDGE_BIND_ADDRESS=0.0.0.0        # 127.0.0.1 si un proxy/pare-feu amont termine le TLS
EDGE_HTTP_PORT=80                # redirection → HTTPS uniquement
EDGE_HTTPS_PORT=443
PUBLIC_HOST=localhost
EXPOSE_ADMIN_CONSOLES=false      # consoles MinIO/Keycloak non routées par défaut

# PostgreSQL — deux rôles applicatifs distincts (DAT §2.2)
POSTGRES_DB=purple
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERPASSWORD=change-me-postgres
APP_MIGRATOR_PASSWORD=change-me-migrator   # rôle owner, Alembic uniquement
APP_API_PASSWORD=change-me-api             # rôle service NOBYPASSRLS

# DSN consommés par l'API/worker (rôle app_api) et par Alembic (rôle app_migrator)
# Les URL de connexion sont CONSTRUITES par docker-compose à partir des mots de
# passe ci-dessus (source unique : APP_*_PASSWORD). Ne les définissez ici QUE pour
# un usage hors compose (développement local, base externe) :
# DATABASE_URL=postgresql+asyncpg://app_api:<APP_API_PASSWORD>@localhost:5432/purple
# MIGRATION_DATABASE_URL=postgresql+psycopg://app_migrator:<APP_MIGRATOR_PASSWORD>@localhost:5432/purple

# Redis (broker Celery)
REDIS_URL=redis://redis:6379/0

# MinIO — objets chiffrés + Object Lock
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
# Préfixe sous lequel nginx expose MinIO (location /storage/ dans nginx.conf).
# Host et port des URL présignées sont dérivés de la requête entrante (jamais
# figés ici) : EDGE_HTTPS_PORT est donc librement personnalisable sans rien
# resynchroniser côté API. À ne changer que si le préfixe nginx change aussi.
MINIO_PUBLIC_PATH_PREFIX=/storage
# Région S3 : doit correspondre à celle du serveur MinIO (MINIO_SITE_REGION,
# câblé sur la même variable dans docker-compose). us-east-1 = défaut MinIO ;
# ne changez que si votre déploiement MinIO utilise une autre région.
MINIO_REGION=us-east-1
MINIO_SECURE=false                               # TLS terminé au reverse proxy
MINIO_QUARANTINE_BUCKET=quarantine
MINIO_EVIDENCE_BUCKET_PREFIX=evidence            # un bucket par client : evidence-<code>

# Vault — KEK par client (transit engine)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=change-me-vault-token                # jeton API à politique wrap/unwrap only
VAULT_TRANSIT_MOUNT=transit

# Keycloak / OIDC (Authorization Code + PKCE)
KC_ADMIN=admin
KC_ADMIN_PASSWORD=change-me-kc
OIDC_ISSUER=https://localhost/idp/realms/purple
OIDC_CLIENT_ID=purple-cockpit
OIDC_CLIENT_SECRET=change-me-oidc                # confidential client (BFF)
OIDC_REDIRECT_URI=https://localhost/api/auth/callback

# Jetons applicatifs (spec backend v2 §1.3)
JWT_SIGNING_KEY=change-me-32-bytes-minimum-secret
# Chiffrement des secrets TOTP au repos (P2). Optionnel : à défaut, dérivé de JWT_SIGNING_KEY.
TOTP_ENC_KEY=change-me-totp-encryption-key
ACCESS_TOKEN_TTL_SECONDS=600                     # ~10 min
REFRESH_TOKEN_TTL_SECONDS=1209600                # 14 j, rotation à chaque usage
STEP_UP_MAX_AGE_SECONDS=300                      # réauthentification récente < 5 min

# Comptes locaux de repli (Argon2id) — DÉSACTIVÉS par défaut (spec v2 §1.1)
LOCAL_ACCOUNTS_ENABLED=false

# Sas d'ingestion (cahier §6quater)
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
MAX_EVIDENCE_BYTES=209715200                     # 200 Mo/preuve par défaut
EVIDENCE_PREVIEW_MAX_BYTES=4194304               # 4 Mio : aperçu image inline max dans les livrables (au-delà : référencée par empreinte)
PRESIGN_UPLOAD_TTL_SECONDS=300
PRESIGN_DOWNLOAD_TTL_SECONDS=300                 # ≤ 5 min (cahier §6quater.7)

# Rétention / RGPD
DEFAULT_RETENTION_DAYS=365

# Enrichissement CVE (cahier §6 4bis) — auto-hébergeable
ENRICHMENT_BASE_URL=https://vulnerability.circl.lu
ENRICHMENT_EPSS_URL=https://cve.circl.lu

# ── Comptes de démonstration (créés par `make seed`) ─────────────────────────
# Mots de passe des comptes locaux admin@ / auditeur@ / ciso@purple.local.
# SEED_DEFAULT_PASSWORD s'applique aux trois ; on peut surcharger par compte.
# ⚠ CHANGER ces valeurs avant tout usage réel (et privilégier SSO + MFA).
SEED_DEFAULT_PASSWORD=ChangeMe!2026
# SEED_ADMIN_PASSWORD=
# SEED_AUDITEUR_PASSWORD=
# SEED_CISO_PASSWORD=
