# Copier en .env à la racine puis adapter avant un déploiement réel.
# docker-compose lit automatiquement ce fichier.

# --- PostgreSQL ---
POSTGRES_USER=purplelens
POSTGRES_PASSWORD=changeme-en-prod
POSTGRES_DB=purplelens

# --- MinIO (Evidence Vault) ---
MINIO_ROOT_USER=purplelens
MINIO_ROOT_PASSWORD=changeme-secret-en-prod
S3_BUCKET=purplelens-evidence

# --- Application ---
# Port d'accès web (frontend). http://localhost:8080 par défaut.
WEB_PORT=8080
# 1 = peuple les données de démo au premier démarrage si la base est vide.
# Mettre 0 pour un déploiement vierge.
SEED_ON_START=1
